<AnchorPane prefHeight="661.0" prefWidth="996.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.postofficesystem.announcementController">
   <children>
      <Label layoutX="312.0" layoutY="14.0" prefHeight="50.0" prefWidth="274.0" text="Announcements">
         <font>
            <Font name="System Bold Italic" size="34.0" />
         </font>
      </Label>
      <VBox layoutX="45.0" layoutY="77.0" prefHeight="420.0" prefWidth="515.0">
         <children>
            <Label prefHeight="27.0" prefWidth="510.0" text="All Announcements" wrapText="true">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <ListView fx:id="announcementListView" prefHeight="397.0" prefWidth="515.0" />
         </children>
      </VBox>
      <Label layoutX="638.0" layoutY="100.0" prefHeight="17.0" prefWidth="52.0" text="Title:">
         <font>
            <Font size="14.0" />
