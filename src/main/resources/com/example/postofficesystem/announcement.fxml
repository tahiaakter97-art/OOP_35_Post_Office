      <Button layoutX="797.0" layoutY="353.0" mnemonicParsing="false" onAction="#clearButtonOA" prefHeight="66.0" prefWidth="90.0" text="Clear" />
      <Button layoutX="863.0" layoutY="588.0" mnemonicParsing="false" onAction="#backButtonOA" text="Back" />
   </children>
</AnchorPane>
