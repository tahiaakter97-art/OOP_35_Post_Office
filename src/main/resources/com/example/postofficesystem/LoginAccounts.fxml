<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.postofficesystem.LoginAccountsController">
   <children>
      <AnchorPane layoutX="10.0" layoutY="10.0" prefHeight="400.0" prefWidth="600.0">
         <children>
            <Label layoutX="153.0" layoutY="34.0" prefHeight="53.0" prefWidth="303.0" text="Accounts Officer Login" wrapText="true">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            <Label layoutX="205.0" layoutY="93.0" prefHeight="46.0" prefWidth="102.0" text="Username:">
               <font>
                  <Font size="19.0" />
               </font>
            </Label>
            <TextField fx:id="userNameTF" layoutX="300.0" layoutY="104.0" />
            <Label layoutX="205.0" layoutY="148.0" prefHeight="28.0" prefWidth="90.0" text="Password:">
               <font>
                  <Font size="19.0" />
               </font>
            </Label>
            <TextField fx:id="passwordTF" layoutX="300.0" layoutY="150.0" />
            <Button fx:id="loginButton" layoutX="272.0" layoutY="254.0" mnemonicParsing="false" onAction="#loginButtonOA" text="Login" />
            <Label fx:id="errorLabel" layoutX="184.0" layoutY="325.0" prefHeight="46.0" prefWidth="222.0" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
