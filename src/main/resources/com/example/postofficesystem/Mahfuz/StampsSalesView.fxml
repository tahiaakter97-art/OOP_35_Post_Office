<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="721.0" prefWidth="920.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.postofficesystem.Mahfuz.stampsSalesViewController">
    <children>
        <Label layoutX="380.0" layoutY="60.0" text="Stamp Sales">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <!-- Stamp Type -->
        <Label layoutX="149.0" layoutY="180.0" text="Stamp Type:" />
        <ComboBox fx:id="stampTypeComboBox" layoutX="287.0" layoutY="175.0" prefWidth="220.0" />

        <!-- Quantity -->
        <Label layoutX="149.0" layoutY="250.0" text="Quantity:" />
        <TextField fx:id="stampQuantityTextField"
                   layoutX="287.0" layoutY="244.0"
                   prefHeight="36.0" prefWidth="140.0"
                   promptText="Enter quantity" />

        <!-- Buttons -->
        <Button layoutX="200.0" layoutY="330.0"
                mnemonicParsing="false"
                onAction="#stampCheckStockOnAction"
                prefHeight="40.0" prefWidth="120.0"
                text="Check Stock" />

        <Button layoutX="370.0" layoutY="330.0"
                mnemonicParsing="false"
                onAction="#sellStampOnAction"
                prefHeight="40.0" prefWidth="120.0"
                text="Sell Stamp" />

        <!-- Output Labels -->
        <Label fx:id="availableStockTextArea"
               layoutX="180.0" layoutY="400.0"
               prefWidth="250.0"
               text="" />

        <Label fx:id="stampTotalPriceTextArea"
               layoutX="180.0" layoutY="440.0"
               prefWidth="200.0"
               text="" />

        <Label fx:id="successMessageTextArea"
               layoutX="180.0" layoutY="490.0"
               prefWidth="350.0"
               prefHeight="40.0"
               text="" />

        <!-- Back Button -->
        <Button layoutX="820.0" layoutY="660.0"
                mnemonicParsing="false"
                onAction="#backOnAction"
                prefWidth="70.0"
                text="Back" />
    </children>
</AnchorPane>
