<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.postofficesystem.UserLogInDashboardController">

    <children>
        <AnchorPane layoutX="10.0" layoutY="10.0" prefHeight="589.0" prefWidth="839.0">
            <children>

                <Label layoutX="216.0" layoutY="34.0" prefHeight="58.0" prefWidth="429.0" text="Welcome to Post Office System">
                    <font>
                        <Font name="Arial Bold Italic" size="25.0" />
                    </font>
                </Label>

                <Label layoutX="388.0" layoutY="104.0" text="LogIn">
                    <font>
                        <Font name="Arial Bold" size="23.0" />
                    </font>
                </Label>

                <Label layoutX="308.0" layoutY="301.0" text="Create New Account">
                    <font>
                        <Font name="Arial Bold" size="23.0" />
                    </font>
                </Label>

                <Label layoutX="172.0" layoutY="160.0" text="User" />
                <Label layoutX="170.0" layoutY="207.0" text="Password" />

                <Label layoutX="172.0" layoutY="356.0" text="User" />
                <Label layoutX="170.0" layoutY="391.0" text="Password" />
                <Label layoutX="170.0" layoutY="431.0" text="Confirm Password" />

                <!-- LOGIN SECTION -->
                <ComboBox fx:id="userComboBox" layoutX="292.0" layoutY="156.0" prefWidth="150.0" promptText="Select User" />

                <PasswordField fx:id="passLogIn" layoutX="292.0" layoutY="203.0" />

                <!-- SHOW PASSWORD FIELD -->
                <TextField fx:id="showPasswordField" layoutX="292.0" layoutY="203.0" prefWidth="150.0" visible="false" />

                <CheckBox fx:id="showPass" layoutX="475.0" layoutY="207.0" onAction="#showPassword" text="Show Password" />

                <Button layoutX="292.0" layoutY="255.0" onAction="#Login" text="LogIn" />

                <Button layoutX="420.0" layoutY="255.0" onAction="#forgetPassword" text="Forget Password" />

                <Label fx:id="loginInfo" layoutX="580.0" layoutY="247.0" prefWidth="200.0" wrapText="true" />

                <!-- CREATE ACCOUNT SECTION -->
                <TextField fx:id="userField" layoutX="292.0" layoutY="352.0" />

                <PasswordField fx:id="password" layoutX="292.0" layoutY="387.0" />

                <PasswordField fx:id="confirmPassword" layoutX="292.0" layoutY="427.0" />

                <Button layoutX="336.0" layoutY="483.0" onAction="#createAccount" text="Create Account" />

                <Label fx:id="createInfo" layoutX="580.0" layoutY="457.0" prefWidth="200.0" wrapText="true" />

            </children>
        </AnchorPane>
    </children>
</AnchorPane>
