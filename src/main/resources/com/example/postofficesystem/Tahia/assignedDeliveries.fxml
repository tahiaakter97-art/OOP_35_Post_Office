<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="636.0" prefWidth="816.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.postofficesystem.Tahia.assignedDeliveriesController">

    <children>

        <Label layoutX="287.0" layoutY="14.0" text="Assigned Deliveries">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <TableView fx:id="assignedDeliveriesTV" layoutX="93.0" layoutY="299.0" prefHeight="263.0" prefWidth="648.0">
            <columns>
                <TableColumn fx:id="deliveryIDTC" prefWidth="120.0" text="Delivery ID" />
                <TableColumn fx:id="mailTypeTC" prefWidth="106.0" text="Mail Type" />
                <TableColumn fx:id="deliveryStatusTC" prefWidth="127.0" text="Delivery Status" />
                <TableColumn fx:id="receiverNameTC" prefWidth="142.0" text="Receiver Name" />
                <TableColumn fx:id="deliveryAddressTC" prefWidth="152.0" text="Delivery Address" />
            </columns>
        </TableView>

        <Button layoutX="692.0" layoutY="580.0" onAction="#logOutButtonOA" text="Back" />

        <Label layoutX="84.0" layoutY="93.0" text="Delivery ID:" />
        <Label layoutX="87.0" layoutY="144.0" text="Mail Type:" />
        <Label layoutX="262.0" layoutY="206.0" text="Delivery Status:" />
        <Label layoutX="497.0" layoutY="93.0" text="Receiver Name:" />
        <Label layoutX="491.0" layoutY="135.0" text="Delivery Address:" />

        <!-- ✅ FIXED TextField -->
        <TextField fx:id="deliveryIdTF" layoutX="172.0" layoutY="89.0" />
        <TextField fx:id="receiverNameTF" layoutX="592.0" layoutY="89.0" />
        <TextField fx:id="deliveryAddressTF" layoutX="592.0" layoutY="131.0" />

        <ComboBox fx:id="mailTypeCB" layoutX="172.0" layoutY="140.0" />
        <ComboBox fx:id="deliveryStatusCB" layoutX="361.0" layoutY="202.0" />

        <Button layoutX="106.0" layoutY="237.0" onAction="#addDeliveryButtonOA" text="Add Delivery" />
        <Button layoutX="539.0" layoutY="250.0" onAction="#updateDeliveryButtonOA" text="Update Delivery" />

      <Label fx:id="outputLabel" layoutX="148.0" layoutY="576.0" prefHeight="30.0" prefWidth="183.0" text="Label" />

    </children>
</AnchorPane>
