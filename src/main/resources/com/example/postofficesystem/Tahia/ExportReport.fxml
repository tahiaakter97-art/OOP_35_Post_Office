      </Label>
      <Label layoutX="31.0" layoutY="68.0" text="Export Format:" />
      <Label layoutX="31.0" layoutY="105.0" text="From Date:" />
      <Label layoutX="286.0" layoutY="105.0" text="To Date:" />
      <ComboBox fx:id="exportFormatCB" layoutX="115.0" layoutY="64.0" prefHeight="25.0" prefWidth="139.0" />
      <DatePicker fx:id="fromDatePicker" layoutX="96.0" layoutY="101.0" prefHeight="25.0" prefWidth="150.0" />
      <DatePicker fx:id="toDatePicker" layoutX="336.0" layoutY="101.0" prefHeight="25.0" prefWidth="150.0" />
      <Button layoutX="145.0" layoutY="143.0" mnemonicParsing="false" onAction="#generateReportButtonOA" text="Generate Report" />
