            <TableColumn fx:id="dateTC" prefWidth="103.0" text="Date" />
            <TableColumn fx:id="statusTC" prefWidth="101.0" text="Status" />
        </columns>
      </TableView>
      <Label fx:id="statusLabel" layoutX="34.0" layoutY="432.0" prefHeight="39.0" prefWidth="165.0" text="Export Status Message" />
