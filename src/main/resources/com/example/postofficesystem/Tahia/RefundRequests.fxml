      </Label>
      <Label layoutX="38.0" layoutY="69.0" text="Request ID:" />
      <Label layoutX="237.0" layoutY="69.0" text="Reason:" />
      <Label layoutX="38.0" layoutY="107.0" text="Amount:" />
      <TextField fx:id="requestIdTF" layoutX="103.0" layoutY="65.0" prefHeight="25.0" prefWidth="111.0" />
      <TextField fx:id="amountTF" layoutX="103.0" layoutY="103.0" prefHeight="25.0" prefWidth="111.0" />
      <TextArea fx:id="reasonTA" layoutX="287.0" layoutY="49.0" prefHeight="61.0" prefWidth="192.0" />
      <TableView fx:id="refundTableView" layoutX="59.0" layoutY="167.0" prefHeight="158.0" prefWidth="374.0">
